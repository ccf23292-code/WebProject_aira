DATABASE_URL=
PUBLIC_BASE_URL=https://zjuaira.com
SMTP_HOST=smtp.qiye.aliyun.com
SMTP_PORT=465
SMTP_USERNAME=no-reply@zjuaira.com
SMTP_PASSWORD=
SMTP_FROM=no-reply@zjuaira.com
SMTP_FROM_NAME=AIRAWeb
SMTP_USE_TLS=true
DEV_EMAIL_ECHO=false
AUTH_SECRET=
REQUIRE_HTTPS=true

# ─── LLM（文本清洗 / AI 题解，DeepSeek 兼容 OpenAI 协议）───
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=60

# ─── LLM Vision（图片 OCR，默认走阿里通义千问 VL）───
# 不配置时图片类型上传会被拒绝（vision_disabled），其它格式不受影响。
LLM_VISION_API_KEY=
LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_MODEL=qwen-vl-max
LLM_VISION_TIMEOUT_SECONDS=90


