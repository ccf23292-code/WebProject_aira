{
	"auth": {
		"login": {
			"summary": "Authenticate a user with account credentials and issue a bearer token pair.",
			"method": "POST",
			"path": "/api/auth/login",
			"headers": {
				"Content-Type": "application/json; charset=utf-8",
				"X-Request-ID": "optional UUID for tracing duplicated submissions"
			},
			"request": {
				"body": {
					"username": {
						"type": "string",
						"required": true,
						"maxLength": 64,
						"description": "Student ID, email, or phone bound to the account"
					},
					"password": {
						"type": "string",
						"required": true,
						"format": "bcrypt-compatible hash on the wire is not required; transmit plain text over HTTPS",
						"description": "User login password"
					},
					"otp": {
						"type": "string",
						"required": false,
						"length": 6,
						"description": "One-time verification code when MFA is enabled"
					},
					"rememberMe": {
						"type": "boolean",
						"required": false,
						"default": false,
						"description": "Whether to issue a long-lived refresh token (30 days) instead of the default 7 days"
					}
				},
				"example": {
					"username": "20230001",
					"password": "P@ssw0rd!",
					"otp": "123456",
					"rememberMe": true
				}
			},
			"responses": {
				"200": {
					"description": "Login succeeded, tokens issued",
					"body": {
						"userId": "string",
						"displayName": "string",
						"accessToken": "JWT string, expires in 30 minutes",
						"refreshToken": "JWT string, expires in 7 or 30 days depending on rememberMe",
						"roles": [
							"string"
						]
					},
					"example": {
						"userId": "u-8f1c231a",
						"displayName": "张三",
						"accessToken": "eyJhbGciOiJIUzI1...",
						"refreshToken": "eyJhbGciOiJIUzI1...",
						"roles": [
							"student"
						]
					}
				},
				"400": {
					"description": "Missing or invalid parameters",
					"body": {
						"error": "invalid_request",
						"message": "username is required"
					}
				},
				"401": {
					"description": "Authentication failed",
					"body": {
						"error": "invalid_credentials",
						"message": "username or password is incorrect"
					}
				},
				"423": {
					"description": "Account locked after repeated failures",
					"body": {
						"error": "account_locked",
						"message": "Account locked for 15 minutes"
					}
				}
			},
			"errorCodes": [
				{
					"code": "invalid_request",
					"httpStatus": 400,
					"description": "Payload is missing required fields or violates schema"
				},
				{
					"code": "invalid_credentials",
					"httpStatus": 401,
					"description": "Username/password combination does not match"
				},
				{
					"code": "mfa_required",
					"httpStatus": 401,
					"description": "Account enforces OTP but the client did not provide it"
				},
				{
					"code": "account_locked",
					"httpStatus": 423,
					"description": "System temporarily disabled the account after too many failures"
				}
			]
		},
		"register": {
			"summary": "Create a new student account and return the initial auth tokens.",
			"method": "POST",
			"path": "/api/auth/register",
			"headers": {
				"Content-Type": "application/json; charset=utf-8",
				"X-Request-ID": "optional UUID for tracing duplicated submissions"
			},
			"request": {
				"body": {
					"username": {
						"type": "string",
						"required": true,
						"maxLength": 64,
						"description": "Unique login identifier (student ID)"
					},
					"email": {
						"type": "string",
						"required": true,
						"format": "email",
						"description": "Used for verification and password reset"
					},
					"password": {
						"type": "string",
						"required": true,
						"minLength": 8,
						"description": "Must contain letters and numbers"
					},
					"confirmPassword": {
						"type": "string",
						"required": true,
						"description": "Must match password"
					},
					"verificationCode": {
						"type": "string",
						"required": true,
						"length": 6,
						"description": "Email/SMS code verifying ownership"
					},
					"agreeToPolicy": {
						"type": "boolean",
						"required": true,
						"description": "User confirms privacy policy and honor code"
					}
				},
				"example": {
					"username": "20230002",
					"email": "stu02@example.edu",
					"password": "Study#2024",
					"confirmPassword": "Study#2024",
					"verificationCode": "654321",
					"agreeToPolicy": true
				}
			},
			"responses": {
				"201": {
					"description": "Registration succeeded, account activated",
					"body": {
						"userId": "string",
						"displayName": "string",
						"accessToken": "JWT string, expires in 30 minutes",
						"refreshToken": "JWT string, expires in 7 days",
						"onboardingTasks": [
							"string"
						]
					},
					"example": {
						"userId": "u-0b2c9931",
						"displayName": "李四",
						"accessToken": "eyJhbGciOiJIUzI1...",
						"refreshToken": "eyJhbGciOiJIUzI1...",
						"onboardingTasks": [
							"complete_profile",
							"bind_courses"
						]
					}
				},
				"400": {
					"description": "Validation failed",
					"body": {
						"error": "invalid_request",
						"message": "email format is invalid"
					}
				},
				"409": {
					"description": "Username or email already exists",
					"body": {
						"error": "conflict",
						"message": "username already registered"
					}
				},
				"422": {
					"description": "Verification code is missing or incorrect",
					"body": {
						"error": "invalid_verification_code",
						"message": "verification code expired"
					}
				}
			},
			"errorCodes": [
				{
					"code": "invalid_request",
					"httpStatus": 400,
					"description": "Payload fails schema validation or passwords do not match"
				},
				{
					"code": "conflict",
					"httpStatus": 409,
					"description": "Username/email/phone already bound to another account"
				},
				{
					"code": "invalid_verification_code",
					"httpStatus": 422,
					"description": "Provided verification code is wrong or expired"
				},
				{
					"code": "policy_not_accepted",
					"httpStatus": 400,
					"description": "User did not consent to required agreements"
				}
			]
		}
	},
	"course": {
		"getQuestionsByCategory": {
			"summary": "Fetch a sequential list of questions for a specific course category (e.g., a specific past exam paper).",
			"method": "GET",
			"path": "/api/courses/{courseId}/questions",
			"headers": {
				"Authorization": "Bearer <token>"
			},
			"request": {
				"params": {
					"courseId": {
						"type": "integer",
						"required": true,
						"description": "The unique identifier of the course (e.g., 1, 2, 3)"
					}
				},
				"query": {
					"category": {
						"type": "string",
						"required": true,
						"description": "Category name, e.g., '2025-autumn-winter-final' or 'others'"
					},
					"page": {
                            "type": "integer",
						"required": false,
						"default": 1,
						"description": "Page number for pagination"
					},
					"limit": {
						"type": "integer",
						"required": false,
						"default": 20,
						"description": "Number of items per page"
					}
				},
				"example": {
					"courseId": 1,
					"category": "2025-autumn-winter-final",
					"page": 1,
					"limit": 20
				}
			},
			"responses": {
				"200": {
					"description": "Successfully retrieved questions, ordered by sequenceId ascending.",
					"body": {
						"total": "integer",
						"items": [
							{
								"id": "string",
								"courseId": "integer",
								"category": "string",
								"sequenceId": "integer",
								"questionType": "string",
								"sourceUrl": "string",
								"content": {
									"text": "string",
									"imageUrls": ["string"]
								},
								"options": [
									{
										"optionId": "string",
										"text": "string",
										"imageUrls": ["string"]
									}
								],
								"answer": {
									"text": "string",
									"correctOptionIds": ["string"],
									"codeSnippet": "string",
									"codeLanguage": "string"
								}
							}
						]
					},
					"example": {
						"total": 45,
						"items": [
							{
								"id": "q-1001",
								"courseId": 1,
								"category": "2025-autumn-winter-final",
								"sequenceId": 1,
								"questionType": "singleChoice",
								"sourceUrl": "https://example.com/source/123",
								"content": {
									"text": "以下关于数据结构的描述，正确的是？",
									"imageUrls": [
										"https://cdn.example.com/img/q1001-1.png"
									]
								},
								"options": [
									{
										"optionId": "A",
										"text": "链表查找的平均时间复杂度为 O(1)",
										"imageUrls": []
									},
									{
										"optionId": "B",
										"text": "平衡二叉树的高度为 $O(\\log n)$",
										"imageUrls": []
									}
								],
								"answer": {
									"text": "选项B正确, 平衡二叉树的高度为 $O(\\log n)$。",
									"correctOptionIds": ["B"],
									"codeSnippet": "",
									"codeLanguage": ""
								}
							},
							{
								"id": "q-1002",
								"courseId": 1,
								"category": "2025-autumn-winter-final",
								"sequenceId": 2,
								"questionType": "programming",
								"sourceUrl": "https://example.com/source/124",
								"content": {
									"text": "请实现一个快速排序算法。",
									"imageUrls": []
								},
								"options": [],
								"answer": {
									"text": "参考代码如下：",
									"correctOptionIds": [],
									"codeSnippet": "func quickSort(arr []int) []int { ... }",
									"codeLanguage": "go"
								}
							}
						]
					}
				},
				"400": {
					"description": "Missing required query parameters",
					"body": {
						"error": "invalid_request",
						"message": "category query parameter is required"
					}
				},
				"404": {
					"description": "Course not found",
					"body": {
						"error": "not_found",
						"message": "Course with the specified ID does not exist"
					}
				}
			},
			"errorCodes": [
				{
					"code": "invalid_request",
					"httpStatus": 400,
					"description": "Missing or malformed parameters"
				},
				{
					"code": "not_found",
					"httpStatus": 404,
					"description": "Course ID does not exist"
				}
			]
		},
		"getRandomQuestions": {
			"summary": "Fetch a random set of questions from a specific course for practice.",
			"method": "GET",
			"path": "/api/courses/{courseId}/questions/random",
			"headers": {
				"Authorization": "Bearer <token>"
			},
			"request": {
				"params": {
					"courseId": {
						"type": "integer",
						"required": true,
						"description": "The unique identifier of the course"
					}
				},
				"query": {
					"limit": {
						"type": "integer",
						"required": false,
						"default": 10,
						"description": "Number of random questions to return (max 50)"
					}
				},
				"example": {
					"courseId": 1,
					"limit": 5
				}
			},
			"responses": {
				"200": {
					"description": "Successfully retrieved a random set of questions.",
					"body": {
						"items": [
							"Same object structure as getQuestionsByCategory items"
						]
					},
					"example": {
						"items": [
							{
								"id": "q-2055",
								"courseId": 1,
								"category": "others",
								"sequenceId": 42,
								"questionType": "fillBlanks",
								"sourceUrl": "https://example.com/source/456",
								"content": {
									"text": "HTTP 协议的默认端口号是______。",
									"imageUrls": []
								},
                                "options": [],
								"answer": {
									"text": "80",
									"choices": [],
									"codeSnippet": "",
									"codeLanguage": ""
								}
							}
						]
					}
				}
			}
		}
	},
    "llm": {
		"chat": {
			"summary": "Send a message to the AI assistant with context memory and specific question binding.",
			"method": "POST",
			"path": "/api/llm/chat",
			"headers": {
				"Authorization": "Bearer <token>",
				"Content-Type": "application/json"
			},
			"request": {
				"body": {
					"id": {
						"type": "string",
						"required": false,
						"description": "题目唯一标识符。在针对某道题进行第一次提问时必填，后端会去数据库拉取完整题目和答案作为系统提示词喂给大模型。"
					},
					"conversationId": {
						"type": "string",
						"required": false,
						"description": "会话唯一标识符。首次提问为空，后续追问时必填，用于拉取历史上下文。 uuid格式字符串，如 'conv-5f9a3b21'。"
					},
					"message": {
						"type": "string",
						"required": true,
						"description": "具体问题。如果是一键求讲解（第一次），可以传默认文案如 '讲一下'。"
					},
					"model": {
						"type": "string",
						"required": false,
						"default": "default_model",
						"description": "选择的大模型类型。"
					}
				},
				"example": {
					"id": "q-1001",
					"conversationId": "",
					"message": "请帮我详细解析一下这道题,我不明白为什么选B。",
					"model": "gemini-1.5-pro"
				}
			},
			"responses": {
				"200": {
					"description": "AI reply received successfully.",
					"body": {
						"conversationId": "string",
						"reply": "string",
						"tokensUsed": "integer"
					},
					"example": {
						"conversationId": "conv-5f9a3b21",
						"reply": "好的！这道题考察的是...（Markdown 格式的 AI 回答）...",
						"tokensUsed": 450
					}
				},
				"404": {
					"description": "Question ID or Conversation ID not found",
					"body": {
						"error": "not_found",
						"message": "The specified question does not exist."
					}
				}
			}
		}
	}
}