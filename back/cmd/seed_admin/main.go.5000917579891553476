package main

import (
	"errors"
	"flag"
	"fmt"
	"log"
	"strings"
	"time"

	"golang.org/x/crypto/bcrypt"
	"gorm.io/gorm"

	"warehouse-web/models"
	"warehouse-web/services"
)

func main() {
	username := flag.String("username", "admin", "admin username")
	password := flag.String("password", "", "admin password")
	email := flag.String("email", "admin@example.com", "admin email")
	nickname := flag.String("nickname", "admin", "admin nickname")
	flag.Parse()

	if strings.TrimSpace(*password) == "" {
		log.Fatal("password is required")
	}

	db, err := services.InitPostgres()
	if err != nil {
		log.Fatalf("database init failed: %v", err)
	}
	if err := db.AutoMigrate(&models.User{}, &models.UserProfile{}); err != nil {
		log.Fatalf("database migrate failed: %v", err)
	}

	hash, err := bcrypt.GenerateFromPassword([]byte(*password), bcrypt.DefaultCost)
	if err != nil {
		log.Fatalf("hash password: %v", err)
	}

	now := time.Now().UTC()
	usernameValue := strings.TrimSpace(*username)
	emailValue := strings.TrimSpace(*email)
	nicknameValue := strings.TrimSpace(*nickname)
	usernameKey := strings.ToLower(usernameValue)
	emailKey := strings.ToLower(emailValue)

	var user models.User
	if err := db.Transaction(func(tx *gorm.DB) error {
		if err := tx.Where("LOWER(username) = ?", usernameKey).First(&user).Error; err != nil {
			if !errors.Is(err, gorm.ErrRecordNotFound) {
				return fmt.Errorf("load admin user: %w", err)
			}

			if err := tx.Where("LOWER(email) = ?", emailKey).First(&user).Error; err != nil && !errors.Is(err, gorm.ErrRecordNotFound) {
				return fmt.Errorf("load admin email: %w", err)
			}
		}

		if user.ID == 0 {
			user = models.User{
				Username:     usernameValue,
				Email:        emailValue,
				PasswordHash: string(hash),
				Role:         models.RoleAdmin,
				CreatedAt:    now,
				UpdatedAt:    now,
			}
			if err := tx.Create(&user).Error; err != nil {
				return fmt.Errorf("create admin user: %w", err)
			}
		} else {
			user.Username = usernameValue
			user.Email = emailValue
			user.PasswordHash = string(hash)
			user.Role = models.RoleAdmin
			user.UpdatedAt = now
			if err := tx.Save(&user).Error; err != nil {
				return fmt.Errorf("update admin user: %w", err)
			}
		}

		var profile models.UserProfile
		if err := tx.Where("user_id = ?", user.ID).First(&profile).Error; err != nil {
			if !errors.Is(err, gorm.ErrRecordNotFound) {
				return fmt.Errorf("load admin profile: %w", err)
			}
			profile = models.UserProfile{
				UserID:    user.ID,
				Nickname:  nicknameValue,
				AvatarURL: "",
				Level:     1,
				CreatedAt: now,
				UpdatedAt: now,
			}
			if err := tx.Create(&profile).Error; err != nil {
				return fmt.Errorf("create admin profile: %w", err)
			}
			return nil
		}

		profile.Nickname = nicknameValue
		profile.UpdatedAt = now
		if err := tx.Save(&profile).Error; err != nil {
			return fmt.Errorf("update admin profile: %w", err)
		}
		return nil
	}); err != nil {
		log.Fatalf("seed admin transaction failed: %v", err)
	}

	fmt.Printf("seeded admin user %s\n", user.Username)
}
