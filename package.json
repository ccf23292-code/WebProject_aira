{
  "name": "aira-web",
  "version": "1.0.0",
  "description": "刷题网站",
  "private": true,
  "workspaces": [
    "web",
    "api",
    "packages/shared",
    "packages/config"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "cd web && npm run dev",
    "dev:api": "cd api && npm run start:dev",
    "build": "npm run build:web && npm run build:api",
    "build:web": "cd web && npm run build",
    "build:api": "cd api && npm run build",
    "start": "npm run start:web",
    "start:web": "cd web && npm start",
    "start:api": "cd api && npm start",
    "test": "npm run test:web && npm run test:api",
    "test:web": "cd web && npm test",
    "test:api": "cd api && npm test",
    "lint": "npm run lint:web && npm run lint:api",
    "lint:web": "cd web && npm run lint",
    "lint:api": "cd api && npm run lint",
    "format": "npm run format:web && npm run format:api",
    "format:web": "cd web && npm run format",
    "format:api": "cd api && npm run format",
    "typecheck": "npm run typecheck:web && npm run typecheck:api",
    "typecheck:web": "cd web && npm run typecheck",
    "typecheck:api": "cd api && npx tsc --noEmit",
    "install:all": "npm install && cd web && npm install && cd ../api && npm install && cd ../packages/shared && npm install && cd ../config && npm install",
    "docker:dev": "docker-compose up",
    "docker:build": "docker-compose build",
    "docker:stop": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}